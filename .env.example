# ── EmailAI environment ──
# Copy to .env and fill in. Production deploy:
#   docker compose -f docker-compose.prod.yml up -d --build

# Postgres password (choose a strong one for production)
POSTGRES_PASSWORD=postgres

# JWT signing key — generate with:  openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-in-production

# Fernet key for encrypting mailbox passwords & API keys — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Public domain. With a real domain, Caddy auto-provisions HTTPS.
# Leave as ":80" to serve over the server's IP on plain HTTP (quick demo).
DOMAIN=:80

# Public base URL — used to build the open-tracking pixel link in outbound mail.
# With a domain use https://your-domain.com
PUBLIC_BASE_URL=http://localhost

# Admin alert email (system-level error notifications)
ADMIN_ALERT_EMAIL=admin@yourcompany.com
